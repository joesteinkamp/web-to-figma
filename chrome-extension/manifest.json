{
  "manifest_version": 3,
  "name": "Web to Figma",
  "version": "3.5.0",
  "description": "One-click capture of any webpage to Figma",
  "permissions": [
    "activeTab",
    "scripting",
    "nativeMessaging",
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://mcp.figma.com/*",
    "http://localhost:19615/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
